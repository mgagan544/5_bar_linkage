<launch>

<rosparam file="$(find 5_bar_linkage_updated_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="5_bar_linkage_updated" args="Revolute 3_position_controller Revolute 4_position_controller Revolute 5_position_controller Revolute 8_position_controller Revolute 9_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/5_bar_linkage_updated/joint_states"/>
</node>

</launch>